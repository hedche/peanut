# Trello API credentials — https://trello.com/power-ups/admin
TRELLO_API_KEY=your_trello_api_key
TRELLO_API_TOKEN=your_trello_api_token
TRELLO_BOARD_ID=your_board_id

# Google AI Studio (Gemini Developer API) — https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key

# Telegram Bot — https://core.telegram.org/bots#creating-a-new-bot
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_WEBHOOK_URL=  # Optional: for on-demand briefings via webhook

# Assistant behavior
ASSISTANT_NAME=Peanut
BRIEFING_TITLE=Daily priorities

# LLM config
# GEMINI_MODEL=gemini-2.5-flash-lite
# TOP_N_FOR_LLM=10
# TOP_PRIORITIES=5
# PRIORITIES_PER_ASSIGNEE=5
# PRIORITIES_UNASSIGNED=3

# Memory persistence
# MEMORY_FILE_PATH=/data/memory.json

# Gmail OAuth2 (read-only access) — Run `python -m app.gmail_auth` after setting CLIENT_ID/SECRET
# https://console.cloud.google.com/apis/credentials
# GMAIL_CLIENT_ID=your_oauth_client_id
# GMAIL_CLIENT_SECRET=your_oauth_client_secret
# GMAIL_REFRESH_TOKEN=your_refresh_token_from_auth_flow
# GMAIL_SENDER_EMAILS=person@example.com,alerts@example.com
